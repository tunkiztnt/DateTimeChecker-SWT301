{
  "info": {
    "_postman_id": "b2c1fd6f-8e77-4c37-91f0-datetimechecker-api",
    "name": "DateTimeChecker API Testing",
    "description": "API testing collection for Date Time Checker based on ProjectIntroduction.docx requirements. This collection tests POST /api/datetime/check without using AI Assistant.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "API01 - Valid date",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"day\": \"30\",\n  \"month\": \"5\",\n  \"year\": \"2026\"\n}"
        },
        "url": "{{baseUrl}}/api/datetime/check"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Response time is under 1000ms', function () { pm.expect(pm.response.responseTime).to.be.below(1000); });",
              "pm.test('Date is valid', function () { pm.expect(pm.response.json().valid).to.eql(true); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
