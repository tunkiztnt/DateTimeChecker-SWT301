{
  "name": "datetimechecker-testing-suite",
  "version": "1.0.0",
  "description": "Unified SQA testing suite for DateTimeChecker",
  "main": "index.js",
  "scripts": {
    "test:unit": "jest --config=jest.config.js",
    "test:api": "playwright test --config=playwright.config.js --grep=\"@api\"",
    "test:e2e": "playwright test --config=playwright.config.js --grep=\"@e2e\"",
    "test:visual": "playwright test --config=playwright.config.js --grep=\"@visual\"",
    "test:visual:update": "playwright test --config=playwright.config.js --grep=\"@visual\" --update-snapshots",
    "test:perf": "node \"Topic 5 - Performance Testing/benchmark/autocannon-test.js\""
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "autocannon": "^7.15.0",
    "jest": "^29.7.0"
  }
}
